{
  "name": "level-dating-app-root",
  "version": "1.0.0",
  "private": true,
  "description": "LEVEL — Monorepo root. Frontend lives in /client, backend in /server.",
  "scripts": {
    "dev":          "node scripts/dev-runner.mjs start",
    "dev:stop":     "node scripts/dev-runner.mjs stop",
    "dev:restart":  "node scripts/dev-runner.mjs restart",
    "dev:status":   "node scripts/dev-runner.mjs status",
    "dev:client":   "npm run dev   --prefix client",
    "dev:server":   "npm run dev   --prefix server",
    "build":        "npm run build --prefix client",
    "start:server": "npm run start --prefix server",
    "install:all":  "npm install   --prefix client && npm install --prefix server",
    "db:reset":     "npm run db:reset --prefix server",
    "db:fresh":     "npm run db:fresh --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

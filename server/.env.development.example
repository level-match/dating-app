# ─── Server · local development overrides ────────────────────────
# Copy to: server/.env.development
#   cp server/.env.development.example server/.env.development
#
# Shared secrets (Supabase, DB, PayMongo, admin keys) stay in server/.env
# This file overrides NODE_ENV / CORS / dev payment flags for `npm run dev`.

NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3000
ALLOW_DEV_PAYMENT_CONFIRM=true

# ─── Server · shared secrets (all environments) ──────────────────
# Copy to: server/.env
#   cp server/.env.example server/.env
#
# Loaded first by server/config/load-env.js, then overridden by:
#   .env.development  (local:  npm run dev)
#   .env.production   (prod:   npm start)
#
# Also copy the matching env-specific file:
#   cp server/.env.development.example server/.env.development
#   cp server/.env.production.example  server/.env.production
#
# Never commit server/.env, .env.development, or .env.production.

# ─── Supabase ────────────────────────────────────────────────────
# Project URL (Settings → API). Required for ES256 / asymmetric JWT verification.
SUPABASE_URL=https://your-project-ref.supabase.co
# Legacy JWT secret (Settings → API → JWT Settings). Still used for HS256 tokens.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Service role key (Settings → API). Server-side Storage uploads only — never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://level:password@localhost:5432/level_db

# ─── Server ──────────────────────────────────────────────────────
PORT=4000

# ─── PayMongo ────────────────────────────────────────────────────
# app.paymongo.com → Developers → API Keys / Webhooks
PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
PAYMONGO_WEBHOOK_SECRET=whsk_xxxxxxxxxxxxxxxxxxxx
# Comma-separated; must match methods enabled on your PayMongo account
PAYMONGO_PAYMENT_METHODS=qrph

# ─── Stripe (optional alternative gateway) ───────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── Tier pricing (PHP centavos — ₱1 = 100 centavos) ─────────────
PRICE_PLUS_CENTAVOS=49900
PRICE_PRIME_CENTAVOS=199000

# ─── Subscription rules ──────────────────────────────────────────
GRACE_PERIOD_HOURS=24
MAX_PAYMENT_RETRIES=3

# ─── Admin auth ──────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_JWT_SECRET=replace_with_48_byte_hex_for_access_tokens
ADMIN_REFRESH_SECRET=replace_with_different_48_byte_hex_for_refresh_tokens
ADMIN_SESSION_TIMEOUT_MINUTES=30
ADMIN_MAX_LOGIN_ATTEMPTS=5
ADMIN_LOCKOUT_MINUTES=30

# ─── Seed admin (optional; used by db:fresh / seeds) ─────────────
# SEED_ADMIN_EMAIL=admin@level.app
# SEED_ADMIN_PASSWORD=change-me-in-production

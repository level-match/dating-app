# ─── Server · production overrides ───────────────────────────────
# Copy to: server/.env.production
#   cp server/.env.production.example server/.env.production
#
# Shared secrets (Supabase, DB, PayMongo, admin keys) stay in server/.env
# This file overrides NODE_ENV / CORS / payment flags for `npm start` on the Droplet.

NODE_ENV=production
FRONTEND_ORIGIN=https://level.ph
ADMIN_ORIGIN=https://level.ph
ALLOW_DEV_PAYMENT_CONFIRM=false

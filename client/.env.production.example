# ─── Client · production build ───────────────────────────────────
# Copy to: client/.env.production
#   cp client/.env.production.example client/.env.production
#
# Loaded by Vite when running `npm run build`.
# Anon/publishable key is public by design (embedded in the client bundle).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key

# Public API origin (Nginx → Express). Update if your domain differs.
VITE_API_BASE_URL=https://api.level.ph
